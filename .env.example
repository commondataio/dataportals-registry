# Censys API - for scripts that fetch host data (e.g. fetch_opendatasoft_censys.py)
# Use one of the following (do not commit real values):
#
# Option 1 (recommended): Platform API v3 - Personal Access Token from Censys Account > Personal Access Tokens
CENSYS_API_TOKEN=
# Optional: Censys organization ID (UUID) for v3 - see Censys Getting Started / organization ID
CENSYS_ORGANIZATION_ID=
#
# Option 2: Legacy Search API v2 - API ID and secret from Censys account page
CENSYS_API_ID=
CENSYS_API_SECRET=
